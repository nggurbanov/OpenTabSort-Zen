[
  {
    "type": "separator",
    "label": "Group Rules"
  },

  {
    "type": "separator",
    "label": "Skip Domains"
  },

  {
    "type": "separator",
    "label": "Backup & Restore"
  },

  {
    "type": "separator",
    "label": "Look & Feel"
  },
  {
    "type": "checkbox",
    "label": "Minimal style — strip group colors and match Zen's address-bar styling",
    "property": "extensions.zen-auto-organize.minimal-style",
    "defaultValue": false
  },
  {
    "type": "checkbox",
    "label": "Strict rule enforcement — eject tabs from a group when their hostname isn't in that group's rule",
    "property": "extensions.zen-auto-organize.strict-rules",
    "defaultValue": false
  },

  {
    "type": "separator",
    "label": "AI Sorting"
  },
  {
    "type": "dropdown",
    "label": "AI engine",
    "property": "extensions.zen-auto-organize.ai-engine",
    "options": [
      { "label": "Local — Built-in model, limited capability", "value": "local" },
      { "label": "Ollama — Stronger model, requires Ollama running locally", "value": "ollama" },
      { "label": "OpenAI-compatible — Remote or self-hosted /v1/chat/completions", "value": "openai" },
      { "label": "Gemini — Google AI Studio generateContent", "value": "gemini" },
      { "label": "Custom — OpenAI or Ollama-compatible endpoint", "value": "custom" }
    ]
  },
  {
    "type": "checkbox",
    "label": "Allow sending tab titles, URLs, and optional page snippets to the selected provider",
    "property": "extensions.zen-auto-organize.ai-provider-consent",
    "defaultValue": false
  },
  {
    "type": "dropdown",
    "label": "Sorting mode",
    "property": "extensions.zen-auto-organize.ai-sort-mode",
    "defaultValue": "rules-first",
    "options": [
      { "label": "Rules first — Use domain rules, then AI for leftovers", "value": "rules-first" },
      { "label": "Hybrid — Fast rules first, then AI-sort unmatched tabs every run", "value": "hybrid" },
      { "label": "Full AI — Ignore rules and re-cluster all eligible tabs", "value": "full-ai" }
    ]
  },
  {
    "type": "dropdown",
    "label": "When AI assigns a tab to an existing group",
    "property": "extensions.zen-auto-organize.ai-existing-behavior",
    "defaultValue": "always-add",
    "options": [
      { "label": "Always-add — Append the tab's domain to the matched rule (rules grow)", "value": "always-add" },
      { "label": "Transient — Move the tab only, rules untouched", "value": "transient" }
    ]
  },
  {
    "type": "dropdown",
    "label": "When AI creates a new group",
    "property": "extensions.zen-auto-organize.ai-new-group-behavior",
    "defaultValue": "auto-add",
    "options": [
      { "label": "Auto-add — Create the group and save it as a new rule", "value": "auto-add" },
      { "label": "Transient — Create the group only, no rule added", "value": "transient" },
      { "label": "Prompt — Open Zen's edit modal to confirm name and color", "value": "prompt" },
      { "label": "Fresh categories — Re-tidy ALL tabs into AI-invented groups, ignoring rules", "value": "fresh-categories" },
      { "label": "Plan Mode — Preview the AI's plan, pick which groups to keep, optionally re-assign", "value": "identify-only" }
    ]
  },
  {
    "type": "string",
    "label": "Ollama host",
    "property": "extensions.zen-auto-organize.ai-ollama-host",
    "defaultValue": "http://localhost:11434"
  },
  {
    "type": "string",
    "label": "Ollama model",
    "property": "extensions.zen-auto-organize.ai-ollama-model",
    "defaultValue": "qwen2.5:1.5b"
  },
  {
    "type": "checkbox",
    "label": "Keep Ollama model warm — preloads at browser start and keeps it loaded between clicks (faster tidy clicks; uses VRAM continuously)",
    "property": "extensions.zen-auto-organize.ai-ollama-warmup",
    "defaultValue": true
  },
  {
    "type": "string",
    "label": "Local AI batch size (only used when >75 unmatched tabs; smaller = gentler on CPU, larger = faster)",
    "property": "extensions.zen-auto-organize.ai-local-batch-size",
    "defaultValue": "30"
  },
  {
    "type": "separator",
    "label": "Remote Provider Settings"
  },
  {
    "type": "string",
    "label": "OpenAI-compatible endpoint",
    "property": "extensions.zen-auto-organize.ai-openai-endpoint",
    "defaultValue": "",
    "placeholder": "https://api.openai.com/v1"
  },
  {
    "type": "string",
    "label": "OpenAI-compatible API key",
    "property": "extensions.zen-auto-organize.ai-openai-api-key",
    "defaultValue": "",
    "placeholder": "sk-..."
  },
  {
    "type": "string",
    "label": "OpenAI-compatible model",
    "property": "extensions.zen-auto-organize.ai-openai-model",
    "defaultValue": "",
    "placeholder": "gpt-4o-mini"
  },
  {
    "type": "string",
    "label": "Gemini API key",
    "property": "extensions.zen-auto-organize.ai-gemini-api-key",
    "defaultValue": "",
    "placeholder": "AIza..."
  },
  {
    "type": "string",
    "label": "Gemini model",
    "property": "extensions.zen-auto-organize.ai-gemini-model",
    "defaultValue": "",
    "placeholder": "gemini-2.0-flash"
  },
  {
    "type": "string",
    "label": "Custom endpoint",
    "property": "extensions.zen-auto-organize.ai-custom-endpoint",
    "defaultValue": "",
    "placeholder": "https://example.test/v1"
  },
  {
    "type": "string",
    "label": "Custom API key",
    "property": "extensions.zen-auto-organize.ai-custom-api-key",
    "defaultValue": "",
    "placeholder": "optional"
  },
  {
    "type": "string",
    "label": "Custom model",
    "property": "extensions.zen-auto-organize.ai-custom-model",
    "defaultValue": "",
    "placeholder": "model name"
  },
  {
    "type": "dropdown",
    "label": "Custom request format",
    "property": "extensions.zen-auto-organize.ai-custom-format",
    "defaultValue": "openai",
    "options": [
      { "label": "OpenAI-compatible chat", "value": "openai" },
      { "label": "Ollama generate", "value": "ollama" }
    ]
  }
]
